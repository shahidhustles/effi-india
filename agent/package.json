{
  "name": "effi-india-agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file=.env.local --experimental-vm-modules --import tsx/esm src/agent.ts dev",
    "download-files": "node --env-file=.env.local --experimental-vm-modules --import tsx/esm src/agent.ts download-files",
    "build": "tsc",
    "start": "node dist/agent.js dev",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@livekit/agents": "^1.0.48",
    "@livekit/agents-plugin-cartesia": "^1.0.48",
    "@livekit/agents-plugin-deepgram": "^1.0.48",
    "@livekit/agents-plugin-livekit": "^1.0.48",
    "@livekit/agents-plugin-openai": "^1.0.48",
    "@livekit/agents-plugin-silero": "^1.0.48",
    "@livekit/noise-cancellation-node": "^0.1.9",
    "dotenv": "^16.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "patch-package": "^8.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
