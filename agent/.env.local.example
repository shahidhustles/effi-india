# Effi India — Agent Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# ── LiveKit Cloud ─────────────────────────────────────────────────────────────
# From your LiveKit Cloud project → Settings → Keys
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxxxxxxxxx
LIVEKIT_API_SECRET=your_api_secret_here

# ── Vercel AI Gateway ────────────────────────────────────────────────────────
# From vercel.com/dashboard → AI Gateway → API Keys
# Used instead of a direct OpenAI key — routes through Vercel's gateway for
# observability, rate limiting, and unified billing.
VERCEL_AI_GATEWAY_API_KEY=vak-...

# ── Deepgram ─────────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=...

# ── Cartesia ─────────────────────────────────────────────────────────────────
CARTESIA_API_KEY=...

# Single multilingual voice — sonic-3 synthesises in whatever language the
# text is written in, so one voice ID covers all languages.
# Get voice IDs from https://play.cartesia.ai — pick any voice labelled
# "Multilingual" or test with the Cartesia playground.
# The placeholder UUID below is NOT a real voice — replace it.
CARTESIA_VOICE_ID=79a125e8-cd45-4c13-8a67-188112f4dd22

# ── Token server ──────────────────────────────────────────────────────────────
PORT=3001
