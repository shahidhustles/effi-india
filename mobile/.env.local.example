# Mobile app environment variables
# Copy to .env.local and set EXPO_PUBLIC_AGENT_API_URL to your machine's local IP.
#
# Do NOT use localhost/127.0.0.1 when testing on a real device or Android emulator.
# Use your machine's Wi-Fi IP instead (e.g. 192.168.1.42).
#
# iOS Simulator: http://localhost:3001 works fine.
# Real device / Android emulator: use your machine IP, e.g. http://192.168.1.42:3001
#
# Find your IP on macOS: System Settings > Wi-Fi > Details, or run: ipconfig getifaddr en0

EXPO_PUBLIC_AGENT_API_URL=http://localhost:3001
